# Copy this file to .env and edit values if needed.

# Data
DATA_PATH=data/raw/creditcard.csv
PROCESSED_DATA_PATH=data/processed/fraud_features.parquet
FEATURE_STATS_PATH=data/processed/feature_stats.json

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_CONSUMER_GROUP=fraud-scoring-service
STREAM_SLEEP_SECONDS=0.1
STREAM_FRAUD_ALERT_THRESHOLD=0.5

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=fraud_detection
MONGODB_COLLECTION=fraud_alerts
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=fraud_detection
MONGO_COLLECTION=fraud_alerts

# Models
MODEL_PATH=models/fraud_classifier.joblib
XGBOOST_MODEL_PATH=models/xgboost_fraud_detector.joblib
ANOMALY_MODEL_PATH=models/anomaly_detector.joblib
ISOLATION_MODEL_PATH=models/isolation_forest_detector.joblib
VALIDATION_DATA_PATH=models/validation_data.csv
OPTIMAL_THRESHOLD_PATH=models/optimal_threshold.txt
FRAUD_THRESHOLD=0.50

# MLflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=credit-card-fraud-realtime
MLFLOW_REGISTERED_MODEL_NAME=FraudDetector

# API
API_HOST=127.0.0.1
API_PORT=8001
FASTAPI_SCORE_URL=http://127.0.0.1:8001/score
FASTAPI_HEALTH_URL=http://127.0.0.1:8001/health
